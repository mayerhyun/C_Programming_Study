#include <stdio.h>
int plus(int, int);
int minus(int, int);
int main(void)
{
    int a = 10, b = 20;
    int result;
    int (*fptr)(int, int); // plus()함수를 가리키는 포인터변수 선언
    fptr = plus;           // 함수포인터로 함수 가리키기
    // 얘도 배열처럼 &plus라고 쓰지 않아도(써도 문법상 허용됨) plus 함수의 메모리 번지수가 fptr에 저장됩니다.
    result = fptr(a, b); // 함수호출부: result=(* fptr)(a, b) ;
    printf("% d + % d = % d\n", a, b, result);
    fptr = minus;
    result = fptr(a, b);
    printf("%d - %d = %d\n", a, b, result);
}
int plus(int x, int y)
{
    return (x + y);
}
int minus(int x, int y)
{
    return (x - y);
}